# OpenWeather API key
OPENWEATHER_API_KEY=replace_with_openweather_api_key

# Data source: api or file
MAGICMIRROR_DATA_SOURCE=file

# Base URL of your application backend (MagicMirror side)
MAGICMIRROR_API_BASE_URL=https://your-app.example.com

# Optional API token if your backend requires auth
MAGICMIRROR_API_TOKEN=

# Optional custom endpoint templates (defaults shown below)
MAGICMIRROR_PROFILE_PATH_TEMPLATE=/api/users/{user_id}/profile
MAGICMIRROR_AGENDA_PATH_TEMPLATE=/api/users/{user_id}/agenda/today

# If MAGICMIRROR_DATA_SOURCE=file
MAGICMIRROR_PROFILE_FILE_TEMPLATE=data/users/{user_id}/profile.json
MAGICMIRROR_AGENDA_FILE_TEMPLATE=data/users/{user_id}/agenda_today.json

# Face identification local registry
FACE_REGISTRY_PATH=data/vision/face_registry.json
