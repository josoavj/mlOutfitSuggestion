# ======================================
# Version intégration backend MagicMirror
# ======================================

OPENWEATHER_API_KEY=replace_with_openweather_api_key

# Utiliser l'API backend de l'application
MAGICMIRROR_DATA_SOURCE=api
MAGICMIRROR_API_BASE_URL=https://your-magicmirror-backend.example.com
MAGICMIRROR_API_TOKEN=replace_with_api_token_if_needed
MAGICMIRROR_PROFILE_PATH_TEMPLATE=/api/users/{user_id}/profile
MAGICMIRROR_AGENDA_PATH_TEMPLATE=/api/users/{user_id}/agenda/today

# Optionnel en mode api
MAGICMIRROR_PROFILE_FILE_TEMPLATE=data/users/{user_id}/profile.json
MAGICMIRROR_AGENDA_FILE_TEMPLATE=data/users/{user_id}/agenda_today.json

# Variante directe Supabase (si tu veux bypass le backend):
# MAGICMIRROR_DATA_SOURCE=supabase
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
# SUPABASE_ANON_KEY=
# SUPABASE_PROFILE_TABLE=profiles
# SUPABASE_PROFILE_USER_ID_COLUMN=user_id
# SUPABASE_AGENDA_TABLE=agenda_events
# SUPABASE_AGENDA_USER_ID_COLUMN=user_id
# SUPABASE_AGENDA_DATE_COLUMN=start_time
# SUPABASE_AGENDA_TODAY_ONLY=true
# SUPABASE_AGENDA_TITLE_COLUMN=title
# SUPABASE_AGENDA_CATEGORY_COLUMN=event_type
# SUPABASE_AGENDA_TAGS_COLUMN=description
# SUPABASE_PROFILE_GENDER_COLUMN=gender
# SUPABASE_PROFILE_AGE_COLUMN=age
# SUPABASE_PROFILE_HEIGHT_COLUMN=height_cm
# SUPABASE_PROFILE_BODY_SHAPE_COLUMN=morphology
# SUPABASE_PROFILE_STYLE_PREFERENCES_COLUMN=preferred_styles
# SUPABASE_PROFILE_LOCATION_COLUMN=location
# SUPABASE_PROFILE_CLOTHING_SIZE_COLUMN=clothing_size
# SUPABASE_PROFILE_TOP_SIZE_COLUMN=top_size
# SUPABASE_PROFILE_BOTTOM_SIZE_COLUMN=bottom_size
# SUPABASE_PROFILE_SHOE_SIZE_COLUMN=shoe_size
# SUPABASE_PROFILE_BODY_MEASUREMENTS_COLUMN=body_measurements

# Vision + feedback
FACE_REGISTRY_PATH=data/vision/face_registry.json
FEEDBACK_LOG_PATH=data/feedback/events.jsonl

# API security and CORS
API_AUTH_ENABLED=true
API_AUTH_KEY=replace_with_strong_shared_secret
ALLOWED_ORIGINS=https://your-magicmirror-app.example.com
